# ─── Binance API Credentials ─────────────────────────────────────────────────
# Get yours at https://www.binance.com/en/my/settings/api-management
# These are kept server-side only (used only in API routes, never exposed to browser)

BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# ─── Optional ─────────────────────────────────────────────────────────────────
# Override the Binance base URL (e.g. testnet)
# BINANCE_BASE_URL=https://testnet.binance.vision
